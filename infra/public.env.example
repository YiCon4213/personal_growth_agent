# Copy to infra/.env on the deployment host; never commit the populated file.
# Generate with: openssl rand -hex 32
POSTGRES_PASSWORD=replace-with-a-long-random-secret
PUBLIC_DOMAIN=agent.example.com
ACCESS_USER=replace-with-a-private-operator-name
# Generate with: docker run --rm caddy:2.10-alpine caddy hash-password --plaintext 'your-long-password'
# In infra/.env, double each $ as $$ so Compose passes the bcrypt hash literally.
ACCESS_PASSWORD_HASH=replace-with-caddy-bcrypt-hash

# Only loopback-bound diagnostics. Public traffic enters through Caddy on 80/443.
POSTGRES_HOST_IP=127.0.0.1
POSTGRES_HOST_PORT=5433
BACKEND_HOST_IP=127.0.0.1
BACKEND_HOST_PORT=8000
FRONTEND_HOST_IP=127.0.0.1
FRONTEND_HOST_PORT=3000

NPM_REGISTRY=https://registry.npmjs.org

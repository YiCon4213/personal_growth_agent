APP_NAME=personal-growth-agent
ENVIRONMENT=development
API_V1_PREFIX=/api/v1
API_DOCS_ENABLED=false

# Phase 5 HTTP boundary. Keep hosts/origins explicit in production; never use *.
ALLOWED_HOSTS=localhost,127.0.0.1,testserver,backend,frontend
CORS_ALLOWED_ORIGINS=
MAX_REQUEST_BODY_BYTES=12582912
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=120
# Only trust X-Forwarded-For from your own reverse proxy network.
TRUSTED_PROXY_CIDRS=

# Host development Postgres. Compose overrides this URL to use postgres:5432 inside containers.
# Start database only: docker compose -f infra/docker-compose.yml up -d postgres --wait
DATABASE_URL=postgresql+psycopg://personal_growth_agent:personal_growth_agent_dev@localhost:5433/personal_growth_agent
DATABASE_ECHO=false

# Phase 2 DashScope text-embedding-v3 settings.
# Keep the real key only in backend/.env and never commit it.
DASHSCOPE_API_KEY=
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/api/v1
EMBEDDING_MODEL=text-embedding-v3
EMBEDDING_MODEL_VERSION=v3-1024-dense
EMBEDDING_DIMENSION=1024
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=2
EMBEDDING_BATCH_SIZE=10
EMBEDDING_MAX_CONCURRENCY=4

# Advanced RAG candidate limits and direct RRF ranking.
RAG_DENSE_LIMIT=12
RAG_SPARSE_LIMIT=12
RAG_FUSED_LIMIT=20
RAG_FINAL_LIMIT=3
RAG_RRF_K=60
RAG_MIN_DENSE_SCORE=0.35

# Phase 1 DeepSeek/OpenAI-compatible chat settings.
# Keep the real key only in backend/.env and never commit it.
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash
LLM_TIMEOUT_SECONDS=60
CONVERSATION_HISTORY_LIMIT=20

# Phase 3 MCP client settings. stdio commands are denied unless allowlisted.
MCP_TIMEOUT_SECONDS=15
MCP_STDIO_ALLOWED_COMMANDS=uvx
MCP_STDIO_ALLOWED_TARGETS=mcp-server-time
MCP_STDIO_ALLOWED_ENV_KEYS=TZ
MCP_STDIO_ALLOW_ABSOLUTE_COMMANDS=false
MCP_STDIO_ALLOW_WORKING_DIRECTORY=false
# Production remote HTTP/SSE MCP is denied unless the exact HTTPS host is listed.
MCP_REMOTE_ALLOWED_HOSTS=

# Local Time MCP server configuration is persisted through POST /api/v1/mcp/servers:
# transport=stdio, command=uvx, args=["mcp-server-time","--local-timezone=Asia/Shanghai"]

APP_NAME=personal-growth-agent
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Local development Postgres. Start with: cd personal_growth_agent/infra && docker compose up -d
DATABASE_URL=postgresql+psycopg://personal_growth_agent:personal_growth_agent_dev@localhost:5433/personal_growth_agent
DATABASE_ECHO=false

# Current RAG uses deterministic hash vectors; these values are metadata/schema settings until Phase 2.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Planned Phase 1 settings. The current backend does not read them yet.
# Keep the real key only in backend/.env and never commit it.
DEEPSEEK_API_KEY=
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-v4-flash

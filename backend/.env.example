APP_NAME=personal-growth-agent
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

# Local development Postgres. Start with: cd personal_growth_agent/infra && docker compose up -d
DATABASE_URL=postgresql+psycopg://personal_growth_agent:personal_growth_agent_dev@localhost:5433/personal_growth_agent
DATABASE_ECHO=false

# Keep embedding settings centralized so pgvector schema and RAG code stay aligned.
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536

# Future tasks will add real values here. Keep secrets out of source control.
# LLM_API_KEY=
# LLM_BASE_URL=
